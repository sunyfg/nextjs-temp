generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?       @map("email_verified")
  image          String?
  hashedPassword String?         @map("hashed_password")
  age            Int             @default(0)
  isSuperAdmin   Int             @default(0) @map("is_super_admin")
  status         Int             @default(1) @map("status")
  phone          String?         @db.VarChar(32) @map("phone")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  accounts       Account[]
  sessions       Session[]
  userRoles      SysUserRole[]

  @@map("sys_user")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model SysRole {
  id               Int                @id @default(autoincrement())
  roleCode         String             @unique @map("role_code")
  roleName         String             @map("role_name")
  description      String?
  status           Int                @default(1)
  sortOrder        Int                @default(0) @map("sort_order")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  userRoles        SysUserRole[]
  rolePermissions  SysRolePermission[]

  @@map("sys_role")
}

model SysUserRole {
  id        Int       @id @default(autoincrement())
  userId    String    @map("user_id")
  roleId    Int       @map("role_id")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      SysRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("sys_user_role")
}

model SysPermission {
  id               Int                @id @default(autoincrement())
  parentId         Int                @default(0) @map("parent_id")
  permissionName   String             @map("permission_name")
  permissionCode   String?            @map("permission_code")
  type             String             // CATALOG, MENU, BUTTON, API
  path             String?
  component        String?
  icon             String?
  visible          Int                @default(1)
  status           Int                @default(1)
  sortOrder        Int                @default(0) @map("sort_order")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  rolePermissions  SysRolePermission[]

  @@map("sys_permission")
}

model SysRolePermission {
  id           Int           @id @default(autoincrement())
  roleId       Int           @map("role_id")
  permissionId Int           @map("permission_id")
  createdAt    DateTime      @default(now()) @map("created_at")
  role         SysRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   SysPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("sys_role_permission")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("post_status")
}

model BlogUser {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  displayName    String?  @map("display_name")
  email          String?  @unique
  avatar         String?
  hashedPassword String?  @map("hashed_password")
  bio            String?  @db.VarChar(500)
  isSuperAdmin   Int      @default(0) @map("is_super_admin")
  status         Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  posts          Post[]

  @@map("blog_user")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  sort        Int      @default(0)
  visible     Boolean  @default(true)

  posts       Post[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_categories")
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique

  posts     PostTag[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("blog_tags")
}

model Post {
  id             Int        @id @default(autoincrement())
  title          String
  slug           String     @unique
  summary        String?    @db.VarChar(500)
  coverImage     String?    @map("cover_image")

  content        String     @db.LongText
  contentText    String?    @db.Text @map("content_text")

  status         PostStatus @default(DRAFT)
  isTop          Boolean    @default(false) @map("is_top")
  isRecommend    Boolean    @default(false) @map("is_recommend")

  viewCount      Int        @default(0) @map("view_count")

  seoTitle       String?    @map("seo_title")
  seoKeywords    String?    @map("seo_keywords")
  seoDescription String?    @db.VarChar(500) @map("seo_description")

  publishedAt    DateTime?  @map("published_at")

  authorId       Int        @map("author_id")
  author         BlogUser   @relation(fields: [authorId], references: [id])

  categoryId     Int?       @map("category_id")
  category       Category?  @relation(fields: [categoryId], references: [id])

  tags           PostTag[]

  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt])
  @@map("blog_posts")
}

model PostTag {
  postId    Int      @map("post_id")
  tagId     Int      @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

model PostDraft {
  id          Int      @id @default(autoincrement())
  postId      Int?     @map("post_id")

  title       String
  slug        String
  summary     String?  @db.VarChar(500)
  coverImage  String?  @map("cover_image")

  content     String   @db.LongText
  contentText String?  @db.Text @map("content_text")

  isTop       Boolean  @default(false) @map("is_top")
  isRecommend Boolean  @default(false) @map("is_recommend")

  seoTitle       String? @map("seo_title")
  seoKeywords    String? @map("seo_keywords")
  seoDescription String? @db.VarChar(500) @map("seo_description")

  tagIds     String?  @map("tag_ids")

  authorId   Int      @map("author_id")
  categoryId Int?     @map("category_id")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([authorId, slug])
  @@map("blog_post_draft")
}

model CmsFile {
  id           Int      @id @default(autoincrement())
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  displayName  String?  @db.VarChar(255)
  ext          String   @db.VarChar(32)
  mimeType     String   @db.VarChar(100)
  size         Int
  sizeText     String?  @db.VarChar(50)

  rootDir      String   @default("uploads") @db.VarChar(100)
  subDir       String?  @db.VarChar(255)
  relativePath String   @db.VarChar(500)
  absolutePath String?  @db.VarChar(1000)
  accessUrl    String?  @db.VarChar(500)

  remark       String?  @db.VarChar(500)

  isPublic     Boolean  @default(true)
  status       Int      @default(1)
  deleted      Boolean  @default(false)

  createUserId   String? @db.VarChar(64)
  createUserName String? @db.VarChar(100)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([subDir])
  @@index([mimeType])
  @@index([createdAt])
  @@map("cms_file")
}

model CmsUploadDir {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  dir         String   @unique @db.VarChar(255)
  description String?  @db.VarChar(500)

  maxSize     Int?
  allowTypes  String?  @db.VarChar(500)

  enabled     Boolean  @default(true)
  sort        Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_upload_dir")
}
