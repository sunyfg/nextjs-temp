generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  role  String @default("viewer")
  age   Int    @default(0)
}

model Post {
  id      Int    @id @default(autoincrement())
  title   String
  content String
}
